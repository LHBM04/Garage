{
  "version": 3,
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "binaryDir": "${sourceDir}/out/${presetName}"
    },
    {
      "name": "windows-x64-base",
      "inherits": "base",
      "hidden": true,
      "cacheVariables": {
        "GARAGE_BUILD_RUNTIME": "ON",
        "GARAGE_GRAPHICS_GL": "ON"
      }
    },
    {
      "name": "linux-x64-base",
      "inherits": "base",
      "hidden": true,
      "cacheVariables": {
        "GARAGE_BUILD_RUNTIME": "ON",
        "GARAGE_GRAPHICS_GL": "ON"
      }
    },
    {
      "name": "windows-x64-static-base",
      "inherits": "windows-x64-base",
      "hidden": true,
      "cacheVariables": {
        "GARAGE_BUILD_SHARED": "OFF"
      }
    },
    {
      "name": "linux-x64-static-base",
      "inherits": "linux-x64-base",
      "hidden": true,
      "cacheVariables": {
        "GARAGE_BUILD_SHARED": "OFF"
      }
    }
    {
      "name": "windows-x64-shared-base",
      "inherits": "windows-x64-base",
      "hidden": true,
      "cacheVariables": {
        "GARAGE_BUILD_SHARED": "ON"
      }
    },
    {
      "name": "linux-x64-shared-base",
      "inherits": "linux-x64-base",
      "hidden": true,
      "cacheVariables": {
        "GARAGE_BUILD_SHARED": "ON"
      }
    },
    {
      "name": "windows-x64-static-debug",
      "displayName": "x64 Debug Static (Windows)",
      "inherits": "windows-x64-static-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "windows-x64-static-release",
      "displayName": "x64 Release Static (Windows)",
      "inherits": "windows-x64-static-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "windows-x64-shared-debug",
      "displayName": "x64 Debug Shared (Windows)",
      "inherits": "windows-x64-shared-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "windows-x64-shared-release",
      "displayName": "x64 Release Shared (Windows)",
      "inherits": "windows-x64-shared-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "linux-x64-static-debug",
      "displayName": "x64 Debug Static (Linux)",
      "inherits": "linux-x64-static-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "linux-x64-static-release",
      "displayName": "x64 Release Static (Linux)",
      "inherits": "linux-x64-static-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "linux-x64-shared-debug",
      "displayName": "x64 Debug Shared (Linux)",
      "inherits": "linux-x64-shared-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "linux-x64-shared-release",
      "displayName": "x64 Release Shared (Linux)",
      "inherits": "linux-x64-shared-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    }
  ]
}