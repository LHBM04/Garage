{
  "dependencies": [
    "stb",
    "glfw3",
    {
      "name": "imgui",
      "features": [
        "docking-experimental",
        "glfw-binding"
      ]
    },
    "imguizmo",
    "implot",
    "fmt",
    "spdlog",
    "assimp",
    "drlibs"
  ],
  "features": {
    "binding-opengl3": {
      "description": "Enable OpenGL graphics backend",
      "dependencies": [
        "glad",
        "glm",
        {
          "name": "imgui",
          "features": [
            "opengl3-binding"
          ]
        }
      ]
    },
    "binding-dx12": {
      "description": "Enable DirectX 12 graphics backend",
      "dependencies": [
        "directx-headers",
        "directx12-agility",
        {
          "name": "directxmath",
          "features": [
            "dx12"
          ]
        },
        {
          "name": "directxmesh",
          "features": [
            "dx12"
          ]
        },
        {
          "name": "directxtex",
          "features": [
            "dx12"
          ]
        },
        {
          "name": "imgui",
          "features": [
            "dx12-binding"
          ]
        }
      ]
    },
    "binding-openal": {
      "description": "Enable OpenAL audio backend",
      "dependencies": [
        "openal-soft"
      ]
    },
    "binding-xaudio2": {
      "description": "Enable XAudio2 audio backend",
      "dependencies": [
        {
          "name": "directxtk12",
          "features": [
            "xaudio2-9"
          ]
        }
      ]
    },
    "binding-gameinput": {
      "description": "Enable GameInput gamepad backend",
      "dependencies": [
        {
          "name": "directxtk12",
          "features": [
            "gameinput"
          ]
        }
      ]
    }
  }
}
